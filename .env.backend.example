# Backend FastAPI - ejemplo de .env (desarrollo)
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+psycopg2://admin:admin123@localhost:5432/inventario
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventario
DB_USER=admin
DB_PASSWORD=admin123
# Pool opcional
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
# Seguridad
SECRET_KEY=dev-secret-key-change-in-production-123456789
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHARS=true
REQUIRE_UPPERCASE=true
REQUIRE_NUMBERS=true
# Sesión/CSRF
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
CSRF_SECRET=csrf-secret-key-change-in-production
CSRF_TOKEN_EXPIRE_MINUTES=60
# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/inventario.log
# Redis (si se usa)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_HEALTH_CHECK_ENABLED=false
# Health/monitoring
HEALTH_CHECK_ENABLED=true
DB_HEALTH_CHECK_ENABLED=true
PROMETHEUS_ENABLED=false
METRICS_ENABLED=false
# CORS/Hosts (en dev se permiten todos por defecto)
ALLOW_ALL_HOSTS_DEV=true
ALLOW_MOBILE_SCHEMES_DEV=true
LOCAL_DEV_IP=
DEV_CLIENT_PORT=5173
# SMTP (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
