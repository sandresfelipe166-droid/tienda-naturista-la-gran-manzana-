# ==========================================
# INVENTARIO BACKEND - CONFIGURACIÓN AVANZADA
# ==========================================

# ==========================================
# ENTORNO
# ==========================================
ENVIRONMENT=development
DEBUG=true

# ==========================================
# BASE DE DATOS
# ==========================================
DATABASE_URL=postgresql+psycopg2://admin:admin123@localhost:5432/inventario
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventario
DB_USER=admin
DB_PASSWORD=admin123

# Configuración Avanzada de Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==========================================
# SEGURIDAD
# ==========================================
SECRET_KEY=your-super-secret-key-here-min-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Políticas de Contraseña
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHARS=true
REQUIRE_UPPERCASE=true
REQUIRE_NUMBERS=true

# Configuración de Sesión
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# CSRF Protection
CSRF_SECRET=your-csrf-secret-key-change-in-production
CSRF_TOKEN_EXPIRE_MINUTES=60

# API Key (opcional)
API_KEY_ENABLED=false
API_KEY_SECRET=your-api-key-secret

# ==========================================
# CORS - Orígenes Permitidos
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==========================================
# LOGGING AVANZADO
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_FILE_SIZE=10MB
LOG_BACKUP_COUNT=10
LOG_JSON_FORMAT=true

# Integración con servicios externos de logging
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ROLLBAR_TOKEN=your-rollbar-token

# ==========================================
# CACHÉ REDIS
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# TTL para diferentes tipos de caché
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=7200
CACHE_TTL_PRODUCTS=600
CACHE_TTL_USERS=900

# ==========================================
# HEALTH CHECKS
# ==========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=30

DB_HEALTH_CHECK_ENABLED=true
DB_HEALTH_QUERY_TIMEOUT=5

REDIS_HEALTH_CHECK_ENABLED=true
REDIS_HEALTH_TIMEOUT=3

# ==========================================
# BACKUP Y RECOVERY
# ==========================================
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_FREQUENCY_HOURS=24
BACKUP_RETENTION_DAYS=7

# Cloud Backup (AWS S3)
CLOUD_BACKUP_ENABLED=false
AWS_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ==========================================
# MONITORING Y MÉTRICAS
# ==========================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
METRICS_COLLECTION_INTERVAL=60

# Alertas
ALERTS_ENABLED=true
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_RESPONSE_TIME_THRESHOLD=2.0
ALERT_DB_CONNECTION_ERRORS_THRESHOLD=5
ALERT_MEMORY_USAGE_THRESHOLD=80

# ==========================================
# DESPLIEGUE
# ==========================================
DOCKER_ENABLED=false
DOCKER_REGISTRY=your-registry.com
DOCKER_IMAGE_TAG=latest

# SSL/TLS
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# ==========================================
# TESTING
# ==========================================
TESTING=false

# ==========================================
# NOTAS IMPORTANTES
# ==========================================
# 1. Cambia todas las contraseñas por defecto antes de producción
# 2. En producción, usa HTTPS y configura SSL_ENABLED=true
# 3. Configura SENTRY_DSN y ROLLBAR_TOKEN para monitoring de errores
# 4. Ajusta los límites de rate limiting según tus necesidades
# 5. Configura AWS S3 para backups automáticos en producción
# 6. Revisa la documentación en README.md para configuración detallada
