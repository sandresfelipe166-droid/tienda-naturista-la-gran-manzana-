                END as nivel_alerta
            FROM producto p
            LEFT JOIN laboratorio l ON p.id_laboratorio = l.id_laboratorio
            LEFT JOIN seccion s ON p.id_seccion = s.id_seccion
            WHERE 1=1
         AND p.estado = $1) as subq]
