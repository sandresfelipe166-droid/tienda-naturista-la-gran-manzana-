# Backend FastAPI - ejemplo de .env para Producción (Render Docker)
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
# PORT lo establece Render automáticamente
DATABASE_URL=postgresql+psycopg2://<USER>:<PASS>@<HOST>:5432/<DB>?sslmode=require
# Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
# Seguridad
SECRET_KEY=<cadena-aleatoria-64+>
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHARS=true
REQUIRE_UPPERCASE=true
REQUIRE_NUMBERS=true
# Salud/monitoring
HEALTH_CHECK_ENABLED=true
DB_HEALTH_CHECK_ENABLED=true
PROMETHEUS_ENABLED=false
METRICS_ENABLED=false
SSL_ENABLED=false
# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/inventario.log
# CORS/Hosts: en producción el backend permite *.onrender.com por defecto
# Si necesitas forzar explícitos, descomenta:
# CORS_ORIGINS=https://<tu-frontend>.onrender.com
# TRUSTED_HOSTS=<tu-backend>.onrender.com
# Redis (solo si se usa)
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_HEALTH_CHECK_ENABLED=false
